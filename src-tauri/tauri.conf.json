{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "sholat-widget",
  "version": "0.1.0",
  "identifier": "com.sholatwidget.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "tray",
        "title": "Sholat Widget",
        "width": 320,
        "height": 480,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "alwaysOnTop": true,
        "shadow": false,
        "skipTaskbar": true
      },
      {
        "label": "main",
        "title": "Sholat Widget",
        "width": 920,
        "height": 640,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "visible": false,
        "alwaysOnTop": false,
        "center": true,
        "skipTaskbar": true
      },
      {
        "label": "reminder",
        "title": "Pengingat Sholat",
        "width": 340,
        "height": 220,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "alwaysOnTop": true,
        "shadow": false,
        "center": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "assets/sounds/bedug.mp3": "sounds/bedug.mp3",
      "assets/cities_fallback.json": "cities_fallback.json"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}