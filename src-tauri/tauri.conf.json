{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sholat Widget",
  "version": "0.3.1",
  "identifier": "com.sholatwidget.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU4RjNBRERGNzY1NDc1ODkKUldTSmRWUjIzNjN6NkVQTXpTUUh4a055RGd3bm5FRTVxYlhrV3FxTFJjeWk2c0dsTFZoS3lmS1YK",
      "endpoints": [
        "https://github.com/nrmadi02/sholat-widget/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "tray",
        "title": "Sholat Widget",
        "width": 320,
        "height": 480,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "alwaysOnTop": true,
        "shadow": false,
        "skipTaskbar": true
      },
      {
        "label": "main",
        "title": "Sholat Widget",
        "width": 920,
        "height": 640,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "visible": false,
        "alwaysOnTop": false,
        "center": true,
        "skipTaskbar": true
      },
      {
        "label": "reminder",
        "title": "Pengingat Sholat",
        "width": 340,
        "height": 220,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "alwaysOnTop": true,
        "shadow": false,
        "center": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "resources": {
      "assets/sounds/azan.mp3": "sounds/azan.mp3",
      "assets/cities_fallback.json": "cities_fallback.json"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}